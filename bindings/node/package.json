{
  "name": "@pamoja/core",
  "version": "0.1.4",
  "description": "Node.js bindings for the pamoja device SDK core.",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tonywied17/pamoja.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./raw": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "napi": {
    "name": "pamoja-core",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-unknown-linux-gnu",
        "aarch64-apple-darwin"
      ]
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "dist/"
  ],
  "engines": {
    "node": ">= 16"
  },
  "scripts": {
    "build": "napi build --platform --release && tsc -p tsconfig.json",
    "build:native": "napi build --platform --release",
    "build:debug": "napi build --platform && tsc -p tsconfig.json",
    "build:facade": "tsc -p tsconfig.json",
    "test": "node test.js",
    "prepack": "tsc -p tsconfig.json",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5"
  }
}
